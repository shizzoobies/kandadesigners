# Daily Songs - Cloudflare secrets
# Set these via: wrangler secret put <NAME>
# Or via the Cloudflare Pages dashboard: Settings > Environment variables

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Required: Shared passphrase users enter on the auth gate
APP_PASSPHRASE=your-passphrase-here

# Required: Random 32+ character string for HMAC-signing the auth cookie
# Generate one with: openssl rand -hex 32
COOKIE_SIGNING_SECRET=replace-with-32-plus-random-chars

# Optional: Anthropic model to use. Change here to upgrade without a redeploy.
# Default: claude-sonnet-4-6
MODEL_NAME=claude-sonnet-4-6

# Optional: The URL path slug where the app is served.
# This controls the folder name only - update the folder name if you change this.
# Default: daily-songs-x7k2
PATH_SLUG=daily-songs-x7k2
